<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 선택됨 -->
    <item android:state_selected="true">
        <shape>
            <solid android:color="@color/mega_yellow"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>

    <!-- 기본 -->
    <item>
        <shape>
            <solid android:color="@color/mega_card"/>
            <stroke android:width="1dp" android:color="@color/mega_stroke"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>

</selector>