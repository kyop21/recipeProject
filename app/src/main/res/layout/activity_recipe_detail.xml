<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mega_bg">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="@color/mega_yellow"
        app:titleTextColor="@color/mega_black"
        app:navigationIcon="@drawable/baseline_arrow_back_24"
        app:navigationIconTint="@color/mega_black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <!-- 메뉴 이름 -->
            <TextView
                android:id="@+id/tvName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="메뉴 이름"
                android:textStyle="bold"
                android:textSize="22sp"
                android:textColor="@color/mega_black"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- ICE/HOT 토글 -->
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:checkedButton="@id/btnIce"
                app:layout_constraintTop_toBottomOf="@id/tvName"
                app:layout_constraintStart_toStartOf="parent">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnIce"
                    android:layout_width="120dp"
                    android:layout_height="44dp"
                    android:text="ICE"
                    android:textStyle="bold"
                    android:textColor="@color/mega_black"
                    app:backgroundTint="@color/toggle_bg"
                    app:strokeColor="@color/toggle_stroke"
                    app:strokeWidth="1dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHot"
                    android:layout_width="120dp"
                    android:layout_height="44dp"
                    android:text="HOT"
                    android:textStyle="bold"
                    android:textColor="@color/mega_black"
                    app:backgroundTint="@color/toggle_bg"
                    app:strokeColor="@color/toggle_stroke"
                    app:strokeWidth="1dp"/>

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- 레시피 라벨 -->
            <TextView
                android:id="@+id/tvLabelSteps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="레시피"
                android:textStyle="bold"
                android:textColor="@color/mega_black"
                app:layout_constraintTop_toBottomOf="@id/toggleGroup"
                app:layout_constraintStart_toStartOf="parent"/>

            <!-- 레시피 내용 -->
            <TextView
                android:id="@+id/tvSteps"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="내용 없음"
                android:textColor="@color/mega_black"
                android:background="@color/mega_card"
                android:padding="14dp"
                app:layout_constraintTop_toBottomOf="@id/tvLabelSteps"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- 토핑 라벨 -->
            <TextView
                android:id="@+id/tvLabelToppings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="토핑"
                android:textStyle="bold"
                android:textColor="@color/mega_black"
                app:layout_constraintTop_toBottomOf="@id/tvSteps"
                app:layout_constraintStart_toStartOf="parent"/>

            <!-- 토핑 내용 -->
            <TextView
                android:id="@+id/tvToppings"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="없음"
                android:textColor="@color/mega_black"
                android:background="@color/mega_card"
                android:padding="14dp"
                app:layout_constraintTop_toBottomOf="@id/tvLabelToppings"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- 메모 라벨 -->
            <TextView
                android:id="@+id/tvLabelMemo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="메모"
                android:textStyle="bold"
                android:textColor="@color/mega_black"
                app:layout_constraintTop_toBottomOf="@id/tvToppings"
                app:layout_constraintStart_toStartOf="parent"/>

            <!-- 메모 입력 -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilMemo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:boxBackgroundMode="filled"
                app:boxBackgroundColor="@color/mega_card"
                app:boxStrokeColor="@color/mega_stroke"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                app:layout_constraintTop_toBottomOf="@id/tvLabelMemo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etMemo"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:gravity="top"
                    android:hint="예) 샷 1펌프 덜 / 손님 요청 / 주의사항"
                    android:textColor="@color/mega_black"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- 아래 여백 -->
            <View
                android:layout_width="0dp"
                android:layout_height="30dp"
                app:layout_constraintTop_toBottomOf="@id/tilMemo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>