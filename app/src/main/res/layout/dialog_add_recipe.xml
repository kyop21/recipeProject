<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="720dp"
    android:layout_height="wrap_content"
    android:padding="22dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="레시피 추가"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="@color/mega_black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 메뉴 이름 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        app:boxBackgroundMode="filled"
        app:boxBackgroundColor="@color/mega_card"
        app:boxStrokeColor="@color/mega_stroke"
        app:boxCornerRadiusTopStart="14dp"
        app:boxCornerRadiusTopEnd="14dp"
        app:boxCornerRadiusBottomStart="14dp"
        app:boxCornerRadiusBottomEnd="14dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="메뉴 이름"
            android:textColor="@color/mega_black"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- ICE / HOT 탭 -->
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:layout_constraintTop_toBottomOf="@id/tilName"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnIce"
            android:layout_width="120dp"
            android:layout_height="44dp"
            android:text="ICE"
            android:textStyle="bold"
            android:textColor="@color/mega_black"
            app:backgroundTint="@color/toggle_bg"
            app:strokeColor="@color/toggle_stroke"
            app:strokeWidth="1dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHot"
            android:layout_width="120dp"
            android:layout_height="44dp"
            android:text="HOT"
            android:textStyle="bold"
            android:textColor="@color/mega_black"
            app:backgroundTint="@color/toggle_bg"
            app:strokeColor="@color/toggle_stroke"
            app:strokeWidth="1dp"/>

    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- 레시피(steps) -->
    <TextView
        android:id="@+id/tvSteps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="레시피"
        android:textStyle="bold"
        android:textColor="@color/mega_black"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/toggleGroup"
        app:layout_constraintStart_toStartOf="parent"/>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilSteps"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:boxBackgroundMode="filled"
        app:boxBackgroundColor="@color/mega_card"
        app:boxStrokeColor="@color/mega_stroke"
        app:boxCornerRadiusTopStart="14dp"
        app:boxCornerRadiusTopEnd="14dp"
        app:boxCornerRadiusBottomStart="14dp"
        app:boxCornerRadiusBottomEnd="14dp"
        app:layout_constraintTop_toBottomOf="@id/tvSteps"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guideline"
        app:layout_constraintWidth_percent="0.62">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSteps"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:gravity="top"
            android:hint="줄바꿈으로 입력 (예: 1) 시럽 2펌프...)"
            android:textColor="@color/mega_black"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- 우측 영역 분리용 가이드라인 -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.66"/>

    <!-- 토핑 -->
    <TextView
        android:id="@+id/tvToppings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="토핑"
        android:textStyle="bold"
        android:textColor="@color/mega_black"
        app:layout_constraintTop_toTopOf="@id/tvSteps"
        app:layout_constraintStart_toStartOf="@id/guideline"/>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilToppings"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:boxBackgroundMode="filled"
        app:boxBackgroundColor="@color/mega_card"
        app:boxStrokeColor="@color/mega_stroke"
        app:boxCornerRadiusTopStart="14dp"
        app:boxCornerRadiusTopEnd="14dp"
        app:boxCornerRadiusBottomStart="14dp"
        app:boxCornerRadiusBottomEnd="14dp"
        app:layout_constraintTop_toBottomOf="@id/tvToppings"
        app:layout_constraintStart_toStartOf="@id/guideline"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etToppings"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:gravity="top"
            android:hint="예: 휘핑크림, 녹차 파우더"
            android:textColor="@color/mega_black"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- 버튼 -->
    <LinearLayout
        android:id="@+id/rowButtons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal"
        android:gravity="end"
        app:layout_constraintTop_toBottomOf="@id/tilSteps"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            android:layout_width="120dp"
            android:layout_height="46dp"
            android:text="취소"
            android:textColor="@color/mega_black"
            app:backgroundTint="@color/mega_card"
            app:strokeColor="@color/mega_stroke"
            app:strokeWidth="1dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="120dp"
            android:layout_height="46dp"
            android:layout_marginStart="12dp"
            android:text="저장"
            android:textColor="@color/mega_black"
            app:backgroundTint="@color/mega_yellow"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>